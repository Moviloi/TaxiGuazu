# === REQUERIDAS ===

# Groq API (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini API (https://aistudio.google.com/app/apikey) — P5: Provider principal
GEMINI_API_KEY=

# LLM Provider — P5: "gemini" (default), "groq", o "fallback" (Gemini → Groq)
LLM_PROVIDER=fallback

# WhatsApp Cloud API (https://developers.facebook.com/apps/)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# Admin
BOT_PHONE=
ADMIN_PHONE=
ADMIN_API_KEY=

# WhatsApp App Secret (verificación HMAC del webhook — obligatorio)
WHATSAPP_APP_SECRET=

# === OPCIONALES ===

# Teléfono principal adicional
PRINCIPAL_2_PHONE=

# Database Turso (https://turso.io)
TURSO_DATABASE_URL=
TURSO_DATABASE_TOKEN=

# Pricing
COTIZACION_DOLAR=
COTIZACION_REAL=

# Cron secret (para autenticar endpoints de cron)
CRON_SECRET=

# Sentry (monitoreo de errores — https://sentry.io)
# Si no se configura, el SDK opera en modo silencioso (no envía, no crashea).
# Sample rate: 0.1 = 10% de transacciones, 0.0 = deshabilitado.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
