# =============================================================================
# TAXIGUAZÚ BOT — Variables de Entorno
# =============================================================================
# Copiar a .env y completar cada valor.
# Documentación completa: docs/ENV.md
# =============================================================================

# ===== LLM — Proveedores de Lenguaje =====

# API key de Groq Cloud (Llama 3.3 70B)
# → https://console.groq.com/keys → Create API Key
GROQ_API_KEY=

# API key de Google Gemini (opcional, fallback a Groq si no se configura)
# → https://aistudio.google.com/app/apikey → Create API Key
GEMINI_API_KEY=

# Proveedor LLM principal: "gemini" | "groq" | "fallback" (default: fallback)
LLM_PROVIDER=fallback

# ===== WHATSAPP — Meta Cloud API =====

# Token de acceso permanente de WhatsApp Cloud API
# → https://developers.facebook.com/apps/ → tu app → WhatsApp → API Setup → Token de acceso
WHATSAPP_TOKEN=

# ID numérico del número de teléfono registrado en Meta
# → https://developers.facebook.com/apps/ → tu app → WhatsApp → API Setup → Número de teléfono
WHATSAPP_PHONE_ID=

# Token de verificación del webhook (lo elegís vos, debe coincidir con Meta)
# → https://developers.facebook.com/apps/ → tu app → WhatsApp → Configuración → Webhook
WHATSAPP_VERIFY_TOKEN=

# App Secret de Meta para verificación HMAC del webhook
# → https://developers.facebook.com/apps/ → tu app → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=

# Número de WhatsApp del bot en formato internacional (ej: 5491123456789)
BOT_PHONE=

# Teléfono del administrador (recibe notificaciones de errores y comandos)
ADMIN_PHONE=

# ===== SEGURIDAD — API Keys y Cron =====

# Clave que protege las rutas /api/bot/*. Se envía como header x-api-key.
# Generá un UUID o frase segura (ej: tg_XXXXXXXX).
ADMIN_API_KEY=

# String seguro que protege los endpoints /api/cron/*
# Generá cualquier string aleatorio seguro.
CRON_SECRET=

# ===== BASE DE DATOS — Turso (libSQL) =====

# URL de la base de datos Turso (opcional; si no se configura usa SQLite local)
# → https://turso.tech/ → Databases → tu DB → Copy URL
TURSO_DATABASE_URL=

# Token de autenticación Turso (obligatorio si TURSO_DATABASE_URL está configurado)
# → https://turso.tech/ → Databases → tu DB → Generate Token
TURSO_DATABASE_TOKEN=

# ===== OBSERVABILIDAD — Sentry =====

# DSN del proyecto Sentry (opcional; sin configurar, el SDK opera en modo silencioso)
# → https://sentry.io/ → Projects → tu proyecto → Settings → Client Keys (DSN)
SENTRY_DSN=

# ===== OPCIONALES =====

# Teléfono adicional para notificaciones (formato internacional)
PRINCIPAL_2_PHONE=

# Nivel de logging: "debug" | "info" | "warn" | "error" (default: info)
LOG_LEVEL=info

# Cotización manual del dólar blue en ARS (referencia; el sistema usa dolarapi.com)
COTIZACION_DOLAR=

# Cotización manual del real brasileño (BRL) en ARS (referencia; el sistema usa dolarapi.com)
COTIZACION_REAL=
