# =============================================================================
# TAXIGUAZÚ BOT — CONFIGURACIÓN DE ENTORNO
# =============================================================================
# Copiar a .env y completar valores.
# Las variables marcadas como OBLIGATORIAS deben tener valor para que el sistema
# funcione. Las OPCIONALES tienen valor por defecto y pueden dejarse vacías.
# Las flags cognitivas (Evidence, Memory) están deshabilitadas por defecto
# y no afectan el comportamiento actual del sistema.
# BKE y DRL fueron eliminados del código por ADR-014 (2026-07-20).
# =============================================================================

# =============================================================================
# LLM — Proveedores de lenguaje
# =============================================================================

# GROQ_API_KEY (OBLIGATORIA)
# API key de Groq Cloud (Llama 3.3 70B).
# https://console.groq.com/keys → Create API Key
GROQ_API_KEY=

# GEMINI_API_KEY (OPCIONAL)
# API key de Google Gemini (gemini-2.0-flash).
# https://aistudio.google.com/app/apikey → Create API Key
# Si no se configura, el sistema usa Groq como único proveedor LLM.
GEMINI_API_KEY=

# LLM_PROVIDER (OPCIONAL — default: "fallback")
# Define el proveedor LLM principal.
# Valores:
#   "gemini"   → Usa Gemini siempre
#   "groq"     → Usa Groq siempre
#   "fallback" → Gemini principal, Groq como fallback si Gemini falla
# Entorno recomendado: dev=groq, staging=fallback, prod=fallback
LLM_PROVIDER=fallback

# =============================================================================
# WHATSAPP — Meta WhatsApp Cloud API
# =============================================================================

# WHATSAPP_TOKEN (OBLIGATORIA)
# Token de acceso permanente de Meta WhatsApp Cloud API.
# https://developers.facebook.com/apps/ → tu app → WhatsApp → Getting Started
WHATSAPP_TOKEN=

# WHATSAPP_PHONE_ID (OBLIGATORIA)
# ID numérico del número de teléfono registrado en Meta.
# Aparece en el panel de WhatsApp al configurar el webhook.
WHATSAPP_PHONE_ID=

# WHATSAPP_VERIFY_TOKEN (OBLIGATORIA)
# Token de verificación del webhook. Lo elegís vos al configurar
# la URL del webhook en Meta Developers. Debe coincidir exactamente.
WHATSAPP_VERIFY_TOKEN=

# WHATSAPP_APP_SECRET (OBLIGATORIA desde 3fa18b0, 2026-07-04)
# App Secret de Meta. Se usa para verificar la firma HMAC
# de los requests entrantes del webhook (seguridad).
# https://developers.facebook.com/apps/ → tu app → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=

# =============================================================================
# SEGURIDAD — Admin, API Keys, Autenticación
# =============================================================================

# ADMIN_API_KEY (OBLIGATORIA)
# Clave que protege las rutas /api/bot/* (simular, conversaciones, métricas, etc.).
# Se envía como header x-api-key en cada request.
# Usá un UUID, hash o frase segura. No hay generador automático.
# ⚠️ Rotar inmediatamente si se expone en conversaciones o logs.
# Entorno recomendado: distinto valor en dev, staging y prod.
ADMIN_API_KEY=

# BOT_PHONE (OBLIGATORIA)
# Número de WhatsApp del bot en formato internacional (ej: 5491123456789).
# Se usa para identificar mensajes enviados por el propio bot.
BOT_PHONE=

# ADMIN_PHONE (OBLIGATORIA)
# Teléfono del administrador del bot. Recibe notificaciones de errores,
# cotizaciones, y comandos administrativos. Mismo formato internacional.
ADMIN_PHONE=

# PRINCIPAL_2_PHONE (OPCIONAL)
# Teléfono principal adicional. Mismo formato internacional que BOT_PHONE.
# Si se configura, recibe notificaciones administrativas adicionales.
PRINCIPAL_2_PHONE=

# CRON_SECRET (OBLIGATORIA desde a2bba37, 2026-06-27)
# String seguro que protege los endpoints de cron (/api/cron/*).
# Se envía como header o query param. Inventá cualquier string seguro.
CRON_SECRET=

# LOG_LEVEL (OPCIONAL — default: "info" en dev, "warn" en producción)
# Nivel de logging del logger estructurado (src/lib/utils/logger.ts).
# Valores: "debug", "info", "warn", "error"
# "debug" es verbose; "warn" solo muestra advertencias y errores.
# Entorno recomendado: dev=debug, staging=info, prod=warn
LOG_LEVEL=

# =============================================================================
# BASE DE DATOS — Turso (libSQL remoto) / SQLite local
# =============================================================================

# TURSO_DATABASE_URL (OPCIONAL — default: SQLite local)
# URL de la base de datos Turso. Si no se configura, usa SQLite local
# en la ruta determinada por DB_PATH (src/config/constants.ts).
# https://turso.io → Create Database → copiá la URL del dashboard
TURSO_DATABASE_URL=

# TURSO_DATABASE_TOKEN (OPCIONAL — default: SQLite local)
# Token de autenticación para Turso. Obligatorio si TURSO_DATABASE_URL está configurado.
TURSO_DATABASE_TOKEN=

# =============================================================================
# EVIDENCE ENGINE — Shadow Mode
# =============================================================================
# El Evidence Engine (ADR-009) es el pipeline cognitivo de 7 capas
# (Signal → Observation → Fact → Evidence → Knowledge → Belief → Decision)
# que corre en paralelo al pipeline conversacional. En shadow mode, sus
# outputs se registran pero no afectan el comportamiento del sistema.

# EVIDENCE_SHADOW_MODE (OPCIONAL — default: false)
# Habilita el pipeline completo del Evidence Engine en shadow mode.
# Cuando está activo, cada mensaje entrante genera Signal, Observation,
# Fact, Evidence, Knowledge, Belief y Decision (ShadowResult).
# El ShadowResult se captura en lead.service.ts pero no se almacena
# a menos que COGNITIVE_MEMORY_ENABLED=true.
# Impacto: rendimiento (~5-10ms adicionales por mensaje).
# Entorno recomendado: dev=true, staging=true, prod=false
#EVIDENCE_SHADOW_MODE=false

# EVIDENCE_SHADOW_LOGGING (OPCIONAL — default: false)
# Habilita logging detallado del pipeline Evidence Engine en shadow mode.
# true: log [EVIDENCE_SHADOW] con resumen del ShadowResult por mensaje.
# false: solo log de errores.
# Impacto: volumen de logs significativamente mayor.
# Entorno recomendado: dev=true, staging=false, prod=false
#EVIDENCE_SHADOW_LOGGING=false

# =============================================================================
# MEMORY — Cognitive Memory Snapshots
# =============================================================================
# La capa Memory (ADR-010) preserva el par Belief + Decision de cada turno
# cognitivo como un snapshot inmutable. La integración al pipeline está
# pendiente (PRD-01 — lead.service.ts no llama a memoryService.store()).

# COGNITIVE_MEMORY_ENABLED (OPCIONAL — default: false)
# Habilita la persistencia de snapshots cognitivos en la tabla
# cognitive_memory_snapshots. Solo tiene efecto si EVIDENCE_SHADOW_MODE=true
# (porque necesita el ShadowResult como entrada).
# ⚠️ GAP DE INTEGRACIÓN: el código de Memory existe (7 archivos, 45 tests)
# pero lead.service.ts no lo invoca. Activarlo no tiene efecto hoy.
# Ver: docs/certification/H0A_STAGING_HARDENING_AUDIT.md (H0A-07)
# Entorno recomendado: dev=false, staging=false, prod=false
#COGNITIVE_MEMORY_ENABLED=false

# =============================================================================
# OBSERVABILIDAD — Sentry, Métricas
# =============================================================================

# SENTRY_DSN (OPCIONAL)
# DSN del proyecto Sentry para captura de errores.
# Si no se configura, el SDK opera en modo silencioso (no envía, no crashea).
# https://sentry.io → Projects → tu proyecto → Client Keys (DSN)
# Entorno recomendado: dev=vacío, staging=configurado, prod=configurado
SENTRY_DSN=

# SENTRY_TRACES_SAMPLE_RATE (OPCIONAL — default: 0.1)
# Fracción de transacciones sampleadas por Sentry.
# 0.1 = 10%, 0.0 = deshabilitado, 1.0 = 100%.
# Solo tiene efecto si SENTRY_DSN está configurado.
# Entorno recomendado: dev=0.0, staging=0.1, prod=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# PRICING — Cotizaciones manuales
# =============================================================================
# Estas variables son REFERENCIA para el operador. El sistema obtiene las
# cotizaciones automáticamente desde dolarapi.com. Las variables no se leen
# activamente desde process.env — se mencionan en notificaciones al admin
# como recordatorio para verificar valores manuales si es necesario.

# COTIZACION_DOLAR (NO LEÍDA POR EL SISTEMA — referencia manual)
# Cotización manual del dólar blue en ARS.
# El sistema obtiene el valor automáticamente de dolarapi.com.
# Esta variable es solo informativa para el operador.
COTIZACION_DOLAR=

# COTIZACION_REAL (NO LEÍDA POR EL SISTEMA — referencia manual)
# Cotización manual del real brasileño (BRL) en ARS.
# El sistema obtiene el valor automáticamente de dolarapi.com.
# Esta variable es solo informativa para el operador.
COTIZACION_REAL=
