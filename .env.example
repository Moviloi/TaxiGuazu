# === REQUERIDAS ===

# Groq API — https://console.groq.com/keys → Create API Key
GROQ_API_KEY=

# Gemini API — https://aistudio.google.com/app/apikey → Create API Key
GEMINI_API_KEY=

# LLM Provider — P5: "gemini" (default), "groq", o "fallback" (Gemini → Groq)
LLM_PROVIDER=fallback

# WhatsApp Cloud API — https://developers.facebook.com/apps/ → tu app → WhatsApp → Getting Started
# Token y Phone ID aparecen al configurar el webhook.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# Admin
# BOT_PHONE / ADMIN_PHONE: tu número de WhatsApp en formato internacional (ej: 5491123456789)
BOT_PHONE=
ADMIN_PHONE=
# ADMIN_API_KEY = clave que protege las rutas /api/bot/* (simular, conversaciones, métricas, etc.).
# Se envía como header x-api-key en cada request. Inventá cualquier string seguro (UUID, hash, frase).
# No hay generador automático — elegí vos una.
ADMIN_API_KEY=

# WhatsApp App Secret — https://developers.facebook.com/apps/ → tu app → Settings → Basic → App Secret
# Usado para verificar HMAC del webhook.
# OBLIGATORIA desde 3fa18b0 (checkpoint pre-AIT-024a, 2026-07-04).
WHATSAPP_APP_SECRET=

# === OPCIONALES ===

# Teléfono principal adicional (mismo formato internacional)
PRINCIPAL_2_PHONE=

# Database Turso — https://turso.io → Create Database → copiás URL y Token del dashboard
TURSO_DATABASE_URL=
TURSO_DATABASE_TOKEN=

# Pricing — cotizaciones manuales en ARS (fuente: dolarhoy.com, cotizacion-cripto.com.ar)
COTIZACION_DOLAR=
COTIZACION_REAL=

# Cron secret — string que vos inventás para proteger endpoints de cron (/api/cron/*)
# OBLIGATORIA desde a2bba37 (common helpers integration, 2026-06-27).
CRON_SECRET=

# Sentry — https://sentry.io → Projects → tu proyecto → Client Keys (DSN)
# Si no se configura, el SDK opera en modo silencioso (no envía, no crashea).
# Sample rate: 0.1 = 10% de transacciones, 0.0 = deshabilitado.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
