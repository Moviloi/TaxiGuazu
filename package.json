{
  "name": "taxiguazu-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:all": "next start",
    "lint": "next lint",
    "test": "vitest run --config src/config/vitest.config.ts",
    "ael:enforce": "bash ael/contracts/enforce.sh",
    "ael:validate": "npm test && npm run build && bash ael/contracts/enforce.sh",
    "test:watch": "vitest --config src/config/vitest.config.ts",
    "validate-knowledge": "npx tsx scripts/validate-knowledge.ts",
"validate-schema-parity": "npx tsx scripts/validate-schema-parity.ts",
    "seed": "npx tsx scripts/seed-data.ts",
    "migrate:catastro": "npx tsx scripts/migrate-catastro.ts",
    "security-check": "node scripts/precommit-security-check.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/postcss": "^4.0.0",
    "axios": "^1.16.0",
    "groq-sdk": "^1.2.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "typescript": "^5.4.5",
    "vercel": "^54.1.0",
    "vitest": "^4.1.8",
    "xlsx": "^0.18.5"
  }
}
