# Groq API (obligatorio) - Crear cuenta gratis en https://console.groq.com
GROQ_API_KEY=gsk_tu_key_aqui

# Meta/WhatsApp Business API (obligatorio)
# Obtené estos datos del panel de Meta for Developers → WhatsApp → Configuración
WHATSAPP_TOKEN=EAATu_token_aqui
WHATSAPP_PHONE_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=un_token_seguro_para_verificacion

# API Key para el panel admin (obligatorio)
# Usá un valor seguro para proteger las rutas de administración
ADMIN_API_KEY=tu_admin_key_segura

# Teléfono del Bot (este número se conecta a WhatsApp)
BOT_PHONE=+543757646648

# Teléfono del administrador (recibe notificaciones) (obligatorio)
ADMIN_PHONE=+5493757613215

# Cotizaciones (se actualizan automáticamente desde la API)
COTIZACION_DOLAR=1300
COTIZACION_REAL=250

# Turso (base de datos remota, opcional si usás SQLite local)
TURSO_DATABASE_URL=libsql://tu-database.turso.io
TURSO_DATABASE_TOKEN=tu_turso_token
